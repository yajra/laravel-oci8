{
    "name": "yajra/laravel-oci8",
    "description": "Oracle DB driver for Laravel via OCI8",
    "keywords": [
        "yajra",
        "laravel",
        "oracle",
        "oci8",
        "pdo_oci"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Arjay Angeles",
            "email": "aqangeles@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-oci8": ">=3.0.1",
        "ext-pdo": "*",
        "illuminate/database": "^13",
        "illuminate/pagination": "^13",
        "illuminate/support": "^13",
        "illuminate/validation": "^13",
        "yajra/laravel-pdo-via-oci8": "^3.7.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.1.0",
        "laravel/pint": "^1.21",
        "mockery/mockery": "^1.6.12",
        "orchestra/testbench": "^11",
        "phpunit/phpunit": "^12.0.1",
        "rector/rector": "^2.0.9"
    },
    "autoload": {
        "psr-4": {
            "Yajra\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Yajra\\Oci8\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "13.x-dev"
        },
        "laravel": {
            "providers": [
                "Yajra\\Oci8\\Oci8ServiceProvider",
                "Yajra\\Oci8\\Oci8ValidationServiceProvider"
            ]
        }
    },
    "scripts": {
        "docker": "docker run -d -p 49160:22 -p 49161:1521 deepdiver/docker-oracle-xe-11g",
        "test": "./vendor/bin/phpunit",
        "pint": "./vendor/bin/pint",
        "rector": "./vendor/bin/rector",
        "stan": "./vendor/bin/phpstan analyse --memory-limit=2G --ansi --no-progress --no-interaction --configuration=phpstan.neon.dist",
        "pr": [
            "@rector",
            "@pint",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
